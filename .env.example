# Optional: Hugging Face Inference API token (free tier available).
# Enables open-source sentence embeddings for retrieval. See README.md.
# HF_TOKEN=

# Optional: override default model (sentence-transformers/all-MiniLM-L6-v2)
# HF_EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional: SQLite database file path
# DATABASE_PATH=data/policy-compass.db

# Set to 1 or true to force TF–IDF only (no embedding API calls)
# DISABLE_EMBEDDINGS=
